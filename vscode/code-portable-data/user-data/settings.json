{
  "npm.runSilent": true,
  "npm.packageManager": "yarn",
  //
  "npm-intellisense.importLinebreak": "",
  "npm-intellisense.scanDevDependencies": true,
  //
  "github.copilot.inlineSuggest.enable": false,
  "github.copilot.enable": { "*": false, "yaml": false, "plaintext": false, "markdown": true, "shellscript": true },
  //
  "go.toolsManagement.autoUpdate": true,
  //
  "autoimport.filesToScan": "**/*.{ts,tsx,js,jsx,md,mdx}",
  "autoimport.useSemiColon": false,
  //
  "path-intellisense.showHiddenFiles": true,
  //
  "git.enableStatusBarSync": false,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.smartCommitChanges": "all",
  "git.postCommitCommand": "sync",
  "git.decorations.enabled": true,
  //
  "gistpad.treeIcons": false,
  //
  "scm.countBadge": "off",
  "scm.diffDecorations": "gutter",
  "scm.repositories.visible": 0,
  "scm.diffDecorationsGutterWidth": 1,
  "scm.diffDecorationsGutterVisibility": "hover",
  //
  "conventionalCommits.autoCommit": true,
  "conventionalCommits.promptBody": false,
  "conventionalCommits.promptScopes": false,
  "conventionalCommits.promptFooter": false,
  "conventionalCommits.showNewVersionNotes": false,
  "conventionalCommits.silentAutoCommit": true,
  //
  "tailwindcss.jsxPropImportChecking": false,
  "tailwindcss.colorDecorators": "off",
  //
  "jsonColorToken.colorTokenCasing": "Lowercase",
  "jsonColorToken.languages": ["json", "jsonc", "javascript", "javascriptReact"],
  //
  "mdb.sendTelemetry": false,
  "mdb.confirmRunAll": false,
  "mdb.showMongoDBHelpExplorer": false,
  //
  "taskExplorer.enableSideBar": true,
  "taskExplorer.showLastTasks": false,
  "taskExplorer.enableExplorerView": false,
  "taskExplorer.showFavoritesButton": false,
  //
  "breadcrumbs.enabled": false,
  //
  "notebook.insertToolbarLocation": "betweenCells",
  "notebook.consolidatedRunButton": true,
  "notebook.cellFocusIndicator": "gutter",
  "notebook.markup.fontSize": 14,
  "notebook.showCellStatusBar": "visibleAfterExecute",
  //
  "editor.fontLigatures": true,
  "editor.glyphMargin": true,
  "editor.folding": false,
  "editor.fontWeight": 100,
  "editor.fontSize": 12.6,
  "editor.fontFamily": "OperatorMonoSSmLig-Book",
  "editor.quickSuggestions": { "strings": true },
  "editor.matchBrackets": false,
  "editor.lineHeight": 20,
  "editor.codeLens": false,
  "editor.lineNumbers": "off",
  "editor.minimap.enabled": false,
  "editor.tabSize": 2,
  "editor.padding.top": 14,
  "editor.padding.bottom": 14,
  "editor.smoothScrolling": true,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.verticalScrollbarSize": 5,
  "editor.guides.indentation": false,
  "editor.inlineSuggest.enabled": true,
  "editor.guides.highlightActiveIndentation": false,
  "editor.guides.bracketPairsHorizontal": false,
  "editor.occurrencesHighlight": true,
  "editor.selectionHighlight": true,
  //
  "editor.renderWhitespace": "selection",
  "editor.renderLineHighlight": "none",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  //
  "indenticator.color.dark": "rgba(255,255,255,.1)",
  //
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontWeight": 100,
  "terminal.integrated.fontWeightBold": 100,
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.letterSpacing": 1,
  "terminal.integrated.cursorStyle": "line",
  //
  "workbench.fontAliasing": "auto",
  "workbench.enableExperiments": false,
  "workbench.list.smoothScrolling": true,
  "workbench.editor.restoreViewState": false,
  "workbench.statusBar.visible": true,
  "workbench.editor.showIcons": false,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.pinnedTabSizing": "compact",
  "workbench.editor.decorations.badges": false,
  "workbench.colorTheme": "Yi Dark",
  "workbench.preferredDarkColorTheme": "Yi Dark",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.tree.renderIndentGuides": "none",
  "workbench.activityBar.visible": true,
  //
  "explorer.autoReveal": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.compactFolders": false,
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": true,
  "explorer.incrementalNaming": "smart",
  "explorer.openEditors.visible": 0,
  //
  "window.zoomLevel": 0,
  "window.titleBarStyle": "native",
  "window.nativeTabs": false,
  "window.nativeFullScreen": false,
  "window.newWindowDimensions": "inherit",
  //
  "files.restoreUndoStack": false,
  "files.associations": { "*.mdx": "markdown", "*.zsh": "shellscript" },
  //
  "files.exclude": { "**/node_modules": true, "**/package-lock.json": true, "**/yarn.lock": true },
  "search.exclude": { "**/.cache": true, "**/.vscode": true, "**/.github": true, "**/public": true, "**/yarn.lock": true, "**/package-lock.json": true },
  //
  "debug.console.wordWrap": false,
  //
  "prettier.tabWidth": 2,
  "prettier.printWidth": 180,
  "prettier.semi": false,
  "prettier.trailingComma": "none",
  "prettier.singleQuote": true,
  "prettier.jsxSingleQuote": true,
  "prettier.bracketSpacing": true,
  "prettier.arrowParens": "avoid",
  //
  "eslint.packageManager": "yarn",
  //
  "css.validate": false,
  //
  "scss.validate": false,
  //
  "html.format.wrapLineLength": 180,
  "html.format.indentInnerHtml": true,
  "html.format.wrapAttributes": "preserve-aligned",
  "html.completion.attributeDefaultValue": "singlequotes",
  //
  "javascript.format.semicolons": "remove",
  "javascript.preferences.quoteStyle": "single",
  "javascript.suggest.completeJSDocs": false,
  //
  "js/ts.implicitProjectConfig.checkJs": false,
  //
  "typescript.check.npmIsInstalled": false,
  "typescript.format.semicolons": "remove",
  "typescript.preferences.quoteStyle": "single",
  "typescript.suggest.completeJSDocs": false,
  "typescript.surveys.enabled": false,
  //
  "[xml]": { "editor.wordWrap": "off" },
  "[markdown]": { "editor.wordWrap": "off" },
  "[html]": { "editor.defaultFormatter": "vscode.html-language-features" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]": { "editor.defaultFormatter": "vscode.typescript-language-features" },
  "[typescript]": { "editor.defaultFormatter": "vscode.typescript-language-features" },
  "[javascriptreact]": { "editor.defaultFormatter": "vscode.typescript-language-features" },
  "[typescriptreact]": { "editor.defaultFormatter": "vscode.typescript-language-features" },
  //
  "security.workspace.trust.enabled": false,
  //
  "emmet.includeLanguages": { "javascript": "javascriptreact" },
  //
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  //
  "telemetry.telemetryLevel": "off",
  //
  "emojisense.languages": { "markdown": true, "plaintext": { "markupCompletionsEnabled": false, "emojiDecoratorsEnabled": false }, "scminput": true, "mdx": true },
  //
  "editor.semanticHighlighting.enabled": true,
  "editor.semanticTokenColorCustomizations": { "rules": {} },
  "editor.tokenColorCustomizations": { "textMateRules": [] },
  //
  "workbench.colorCustomizations": {
    "focusBorder": "#db6df100",
    "statusBarItem.remoteBackground": "#db6df100",
    "editor.wordHighlightStrongBackground": "#3f434d",
    "editor.wordHighlightBackground": "#3f434d",
    "tab.activeBorder": "#0000",
    "scrollbar.shadow": "#0000"
  },
  //
  "customizeUI.titleBar": "inline",
  "customizeUI.listRowHeight": 21,
  "customizeUI.font.monospace": "OperatorMonoSSmLig-Book",
  "customizeUI.fontSizeMap": { "13px": "12.6px", "12px": "12.6px", "window-title": "12px", "tab-title": "12px", "monospace": "5.5px" },
  //
  "customizeUI.stylesheet": {
    //
    ".suggest-input-container": "padding: 3px 4px 3px !important;",
    // sidebar workspace title
    ".monaco-workbench .part.sidebar>.title>.title-label h2": "text-transform: none !important; opacity: 0.5 !important",
    ".monaco-workbench .activitybar>.content :not(.monaco-menu)>.monaco-action-bar .badge .badge-content": "display: none !important",
    // sidebar: source control icons
    "div.part.sidebar.left#workbench\\.parts\\.sidebar li.action-item>a.action-label.codicon-new-file": "display: none !important",
    "div.part.sidebar.left#workbench\\.parts\\.sidebar li.action-item>a.action-label.codicon-new-folder": "display: none !important",
    "div.part.sidebar.left#workbench\\.parts\\.sidebar li.action-item>a.action-label.codicon-refresh[title='Refresh Environments']": "display: block !important",
    "div.part.sidebar.left#workbench\\.parts\\.sidebar li.action-item>a.codicon-collapse-all": "display: none !important",
    //
    "div.editor-group-container.active ul.actions-container>li.action-item.menu-entry>a.action-label.codicon-compare-changes": "display: none !important",
    "div.editor-group-container.active ul.actions-container>li.action-item>div.monaco-dropdown>div.dropdown.label>a.action-label.codicon-toolbar-more": "display: none !important",
    //
    ".action-label": "font-size: 16px !important",
    //
    "div.tabs-and-actions-container .action-label.codicon-toolbar-more": "display: none !important",
    "div.tabs-and-actions-container .action-label.codicon-split-horizontal": "display: none !important",
    // sidebar: gistpad icons
    "div.part.sidebar.left#workbench\\.parts\\.sidebar li.action-item>a.action-label.codicon-list-tree": "display: none !important",
    "div.part.sidebar.left#workbench\\.parts\\.sidebar li.action-item>a.action-label.codicon-check": "display: none !important",
    "div.part.sidebar.left#workbench\\.parts\\.sidebar li.action-item>a.action-label.codicon-refresh": "display: none !important",
    //
    "div.pane-body div.tree-explorer-viewlet-tree-view div.monaco-list-rows div.monaco-list-row .monaco-tl-row span.monaco-icon-description-container span.label-description": "display: none !important",
    // sidebar: explorer icons
    "div.part.panel.basepanel.bottom#workbench\\.parts\\.panel li.action-item>a.action-label": "font-size: 10px !important",
    "div.part.panel.basepanel.bottom#workbench\\.parts\\.panel li.action-item>a.action-label.codicon-trash": "font-size: 16px !important",
    "div.part.panel.basepanel.bottom#workbench\\.parts\\.panel li.action-item>a.action-label.codicon-split-horizontal": "font-size: 16px !important",
    "div.part.panel.basepanel.bottom#workbench\\.parts\\.panel li.action-item>a.action-label.codicon-maximize": "font-size: 16px !important",
    "div.part.panel.basepanel.bottom#workbench\\.parts\\.panel li.action-item>a.action-label.codicon-close": "font-size: 16px !important",
    // panel: terminal icons ???
    ".customview-tree .monaco-list .monaco-list-row .custom-view-tree-node-item>.custom-view-tree-node-item-icon": "background-size: 11px !important; opacity: 0.6 !important"
  },
  "tabnine.experimentalAutoImports": true,
  "kite.showWelcomeNotificationOnStartup": false,
  "redhat.telemetry.enabled": false
}
