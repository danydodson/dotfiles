// Place your key bindings in this file to override the defaultsauto[]
[
  {
    "key": "F2",
    "command": "toggle",
    "when": "editorTextFocus || editorFocus || findInputFocussed || emptyWorkspaceSupport || editorFocus || inWelcome || terminal.active || activeEditor == 'gettingStartedPage'",
    "args": {
      "id": "activitybar",
      "value": [{ "workbench.activityBar.visible": false }, { "workbench.activityBar.visible": true }]
    }
  },
  {
    "key": "F3",
    "command": "toggle",
    "when": "editorTextFocus || editorFocus || findInputFocussed || emptyWorkspaceSupport || editorFocus || inWelcome || terminal.active || activeEditor == 'gettingStartedPage'",

    "args": {
      "id": "statusbar",
      "value": [{ "workbench.statusBar.visible": false }, { "workbench.statusBar.visible": true }]
    }
  },
  {
    "key": "F4",
    "command": "toggle",
    "when": "editorTextFocus || editorFocus || findInputFocussed || emptyWorkspaceSupport || editorFocus || inWelcome || terminal.active || activeEditor == 'gettingStartedPage'",
    "args": {
      "id": "codelens",
      "value": [{ "editor.codeLens": false }, { "editor.codeLens": true }]
    }
  },
  {
    "key": "Shift+F2",
    "command": "toggle",
    "when": "editorTextFocus || editorFocus || findInputFocussed || emptyWorkspaceSupport || editorFocus || inWelcome || terminal.active || activeEditor == 'gettingStartedPage'",
    "args": {
      "id": "copilot",
      "value": [{ "github.copilot.inlineSuggest.enable": true }, { "github.copilot.inlineSuggest.enable": false }]
    }
  },
  {
    "key": "Shift+F3",
    "command": "toggle",
    "when": "editorTextFocus || editorFocus || findInputFocussed || emptyWorkspaceSupport || editorFocus || inWelcome || terminal.active || activeEditor == 'gettingStartedPage'",
    "args": {
      "id": "glyphs",
      "value": [{ "editor.glyphMargin": false }, { "editor.glyphMargin": true }]
    }
  },
  {
    "key": "Shift+F4",
    "command": "toggle",
    "when": "editorTextFocus || editorFocus || findInputFocussed || emptyWorkspaceSupport || editorFocus || inWelcome || terminal.active || activeEditor == 'gettingStartedPage'",
    "args": {
      "id": "decorations",
      "value": [
        { "git.decorations.enabled": false, "explorer.decorations.colors": false, "scm.diffDecorations": "none" },
        { "git.decorations.enabled": true, "explorer.decorations.colors": true, "scm.diffDecorations": "gutter" }
      ]
    }
  },
  {
    "key": "Shift+F6",
    "command": "toggle",
    "when": "editorTextFocus || editorFocus || findInputFocussed || emptyWorkspaceSupport || editorFocus || inWelcome || terminal.active || activeEditor == 'gettingStartedPage'",
    "args": {
      "id": "theme",
      "value": [{ "workbench.colorTheme": "Atom One Dark" }, { "workbench.colorTheme": "Yi Dark" }]
    }
  },
  {
    "key": "ctrl+q",
    "command": "-workbench.action.quickOpenView"
  },
  {
    "key": "ctrl+q",
    "command": "-workbench.action.quickOpenNavigateNextInViewPicker",
    "when": "inQuickOpen && inViewsPicker"
  },
  {
    "key": "ctrl+e",
    "command": "-workbench.action.quickOpen"
  },
  {
    "key": "ctrl+e",
    "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
    "when": "inFilesPicker && inQuickOpen"
  },
  {
    "key": "ctrl+e",
    "command": "workbench.files.action.showActiveFileInExplorer"
  },
  {
    "key": "cmd+w",
    "command": "-workbench.action.closeWindow",
    "when": "!editorIsOpen && !multipleEditorGroups"
  },
  {
    "key": "cmd+q",
    "command": "-workbench.action.quit"
  },
  {
    "key": "f8",
    "command": "-editor.action.marker.nextInFiles",
    "when": "editorFocus"
  },
  {
    "key": "f6",
    "command": "-workbench.action.debug.pause",
    "when": "debugState == 'running'"
  },
  {
    "key": "f6",
    "command": "-workbench.action.focusNextPart"
  }
]