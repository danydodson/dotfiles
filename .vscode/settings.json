{
  "files.associations": {
    "**/config/git/config": "gitconfig",
    "**/config/git/ignore": "ignore",
    "**/**/bin/*": "shellscript"
  },
  "shellcheck.ignorePatterns": {
    "**/config/bin/color-path": true,
    "**/config/bin/fzf-scripts": true
  },
  "taskExplorer.exclude": ["**/**/**/**/dracula.py", "**/helpers.sh", "config/shell/*"]
}
