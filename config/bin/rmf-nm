#!/bin/bash

# Find node_module folders under ~/Developer

# Log Helpers
__info() { printf '\033[0;34m[INFO] \033[0;34m%s\033[0;m\n' "$1"; }
__ok() { printf '\033[0;33m[OK] \033[0;36m%s\033[0;m\n' "$1"; }
__err() { printf '\033[0;31m[ERR] \033[0;31m%s\033[0;m\n' "$1"; }

__info "Finding node_modules folders from $(pwd)..."

find ~/Developer -name "node_modules" -print0 -type d -prune | xargs du -chs
