#!/bin/bash

# symlinking helper function for ~/Developer/Dotfiles
# $1 source file in $DOTFILES, assuming ${HOME}/Developer/Dotfiles
# $2 dest file relative to $HOME

# todo: add support for multiple symlinks

__dotfiles_dir="$HOME/Developer/Dotfiles"

# Log Helpers
. "$HOME/Developer/Dotfiles/utils/helpers.sh"
. "$HOME/Developer/Dotfiles/utils/pretty.bash"

__symlinking() {
  printf '\033[0;36m[OK]  \033[0;35m%s\033[0;m -> %s\033[0;m\n' "$1" "$2"
}

__symlink() {
  local sourcepath="${__dotfiles_dir}/${1}"
  local fulltargetpath="${HOME}/${2}"
  local targetdir

  same "$sourcepath" "$fulltargetpath"
  local result=$?

  if ((result == 0)); then
    # properly symlinked
    return
  elif ((result == 10)); then
    __info "Found different ${fulltargetpath}"
    if [[ -z "$CI" ]]; then
      read -p "          Overwrite? [y/N] " -r
      if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        __warn "Skipped ${fulltargetpath}"
        return
      fi
    else
      __ok_ "CI run: skipping ${fulltargetpath}"
      return
    fi
    # OVERWRITE!
  elif ((result != 20)); then
    # could not determine status
    return
  fi

  __symlinking "${fulltargetpath}" "${sourcepath}"

  targetdir="$(dirname "$fulltargetpath")"
  maybemkdir "$targetdir" || return 1
  ln -fns "$sourcepath" "$fulltargetpath"
}

__symlink "$@"
