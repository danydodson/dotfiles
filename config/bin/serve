#!/bin/bash

cd -- "$(dirname "$0")/.." || exit 1

__dotfiles_dir="$PWD"

# Log Helpers
__info() { printf '\033[0;34m[INFO] \033[0;34m%s\033[0;m\n' "$1"; }
__ok() { printf '\033[0;33m[OK] \033[0;36m%s\033[0;m\n' "$1"; }
__err() { printf '\033[0;31m[ERR] \033[0;31m%s\033[0;m\n' "$1"; }

__serve() {
  local port
  port="${1:-8888}"

  __has 'python3' && __info "Using python3 http.server" &&
    python3 -m http.server "$port" &&
    return 0

  __has 'python2' && __info "Using python2 SimpleHTTPServer" &&
    python2 -m SimpleHTTPServer "$port" &&
    return 0

  __has 'http-server' && __info "Using node http-server" &&
    http-server -p "$port" &&
    return 0
}

__serve "$@"
