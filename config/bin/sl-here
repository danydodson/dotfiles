#!/bin/bash

# Create symlink of current dir at ~/.shell.here

# Log Helpers
# . "$HOME/Developer/Dotfiles/utils/helpers.sh"
. "$HOME/Developer/Dotfiles/utils/pretty.bash"

loc=''

if [ "$#" -eq 1 ]; then
  loc=$(realpath "$1")
else
  loc=$(realpath ".")
fi

ln -sfn "${loc}" "$HOME/.shell.here"

__info "here -> $(readlink "$HOME"/.shell.here)"
