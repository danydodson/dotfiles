#!/bin/bash

# Log Helpers
__info() { printf '\033[0;34m[INFO] \033[0;34m%s\033[0;m\n' "$1"; }
__ok() { printf '\033[0;33m[OK] \033[0;36m%s\033[0;m\n' "$1"; }
__err() { printf '\033[0;31m[ERR] \033[0;31m%s\033[0;m\n' "$1"; }

__maybemkdir() {
  if [[ ! -d "$1" ]]; then
    __info "Directory ${1} does not exist."
    if [[ -z "$CI" ]]; then
      read -p "          Create? [y/N] " -r
      [[ ! $REPLY =~ ^[Yy]$ ]] && return 1
    fi
    mkdir -p -- "$1" && __ok "Created ${1}"
  fi
}

__maybemkdir "$1"
