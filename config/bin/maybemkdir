#!/bin/bash

# Log Helpers
. "$HOME/Developer/Dotfiles/utils/helpers.sh"
. "$HOME/Developer/Dotfiles/utils/pretty.bash"

__maybemkdir() {
  if [[ ! -d "$1" ]]; then
    __info "Directory ${1} does not exist."
    if [[ -z "$CI" ]]; then
      read -p "          Create? [y/N] " -r
      [[ ! $REPLY =~ ^[Yy]$ ]] && return 1
    fi
    mkdir -p -- "$1" && __ok "Created ${1}"
  fi
}

__maybemkdir "$1"
