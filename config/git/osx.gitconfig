[user]
    name = danydodson
    email = danydodson@gmail.com

[credential]
	helper = osxkeychain

[web]
	browser = open

# Use Keychain.app: https://stackoverflow.com/a/7552971/230473

[github]
	token = !security find-generic-password -gs \"GitHub API Token\" 2>&1 >/dev/null | awk '/password/ {print $2}' | tr -d \\\"