[user]
  name = "Dany Dodson"
  email = "danydodson@gmail.com"
[credential]
  helper = osxkeychain
[hub]
  protocol = https
[color]
  diff = auto
  status = auto
  branch = auto
  ui = true
[core]
  excludesfile = ~/.config/git/ignore
  editor = vim
[apply]
  whitespace = nowarn
[mergetool]
  keepBackup = false
[difftool]
  prompt = false
[help]
  autocorrect = 1
[push]
  default = simple
[pager]
  branch = false
  tag = false
[init]
    defaultBranch = main