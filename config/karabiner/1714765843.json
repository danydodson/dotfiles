    {
      "description": "command + d = define",
      "type": "basic",
      "from": {
        "key_code": "d",
        "modifiers": {
          "mandatory": [
            "left_command",
            "right_command",
            "right_control",
            "right_shift",
            "right_option"
          ]
        }
      },
      "to": [
        {
          "key_code": "d",
          "modifiers": [
            "left_control",
            "left_command"
          ]
        }
      ]
    },
