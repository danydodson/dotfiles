#!/bin/bash

# battery-status

if test ! "$(uname)" = "Darwin"
  then
  printf ""
  exit 0
fi

battstat=$(pmset -g batt)
time_left=$(echo "$battstat" |
  tail -1 |
  cut -f2 |
  awk -F"; " '{print $3}' |
  cut -d' ' -f1
)

if [[ $(pmset -g ac) == *"No adapter attached."* ]]
then
  emoji='🔋'
else
  emoji='🔌'
fi

if [[ $time_left == *"(no"* || $time_left == *"not"* ]]
then
  time_left='⌛️ '
fi

if [[ $time_left == *"0:00"* ]]
then
  time_left='⚡️ '
fi

printf "\033[1;92m%s  %s \033[0m" "$emoji" "$time_left"