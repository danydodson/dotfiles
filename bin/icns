#!/bin/sh

# ================= // gen-icons //
#
# Description:
#   Convert one or more PNG images into macOS `.icns` icon files.
#   For each PNG input this creates a temporary `.iconset` with
#   the required sizes and uses `iconutil` to build the `.icns`.
#
# Usage:
#   gen-icons <image.png> [more.png ...]
#   gen-icons <directory>    # converts all .png files in directory
#
# Requirements (macOS): `sips`, `iconutil` (bundled on macOS)
#
# Example:
#   gen-icons ~/Pictures/my-icon.png
#   gen-icons icons/ --> # converts all PNGs inside `icons/`
#
# --------------------------------------------------------

set -e

usage() {
	printf "Usage: %s <image.png> [more.png ...]\n" "$(basename "$0")" 1>&2
	exit 1
}

if [ "$#" -eq 0 ]; then
	usage
fi

convert_png() {
	src="$1"
	case "$src" in
		*.png|*.PNG) ;;
		*) printf "Skipping non-png file: %s\n" "$src" 1>&2; return 1;;
	esac

	if [ ! -f "$src" ]; then
		printf "Not a file: %s\n" "$src" 1>&2
		return 1
	fi

	src_dir=$(dirname "$src")
	base=$(basename "$src" .png)
	tmpdir=$(mktemp -d)
	iconset="$tmpdir/$base.iconset"
	mkdir -p "$iconset"

	# Create required icon sizes. Suppress sips output for cleanliness.
	sips -z 16 16   "$src" --out "$iconset/icon_16x16.png" >/dev/null 2>&1 || true
	sips -z 32 32   "$src" --out "$iconset/icon_16x16@2x.png" >/dev/null 2>&1 || true
	sips -z 32 32   "$src" --out "$iconset/icon_32x32.png" >/dev/null 2>&1 || true
	sips -z 64 64   "$src" --out "$iconset/icon_32x32@2x.png" >/dev/null 2>&1 || true
	sips -z 128 128 "$src" --out "$iconset/icon_128x128.png" >/dev/null 2>&1 || true
	sips -z 256 256 "$src" --out "$iconset/icon_128x128@2x.png" >/dev/null 2>&1 || true
	sips -z 256 256 "$src" --out "$iconset/icon_256x256.png" >/dev/null 2>&1 || true
	sips -z 512 512 "$src" --out "$iconset/icon_256x256@2x.png" >/dev/null 2>&1 || true
	sips -z 512 512 "$src" --out "$iconset/icon_512x512.png" >/dev/null 2>&1 || true
	sips -z 1024 1024 "$src" --out "$iconset/icon_512x512@2x.png" >/dev/null 2>&1 || true

	out="$src_dir/$base.icns"
	if command -v iconutil >/dev/null 2>&1; then
		iconutil -c icns -o "$out" "$iconset" >/dev/null 2>&1
		status=$?
		if [ "$status" -eq 0 ]; then
			printf "Created: %s\n" "$out"
		else
			printf "iconutil failed for %s\n" "$src" 1>&2
		fi
	else
		printf "iconutil not found — cannot build .icns\n" 1>&2
		status=2
	fi

	rm -rf "$tmpdir"
	return $status
}

# Process arguments: files or directories
for arg in "$@"; do
	if [ -d "$arg" ]; then
		found=0
		for f in "$arg"/*.png "$arg"/*.PNG; do
			[ -e "$f" ] || continue
			found=1
			convert_png "$f"
		done
		[ "$found" -eq 1 ] || printf "No PNGs found in directory: %s\n" "$arg" 1>&2
	else
		convert_png "$arg"
	fi
done

exit 0

